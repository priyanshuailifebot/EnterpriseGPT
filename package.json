{
  "name": "enterprisegpt",
  "version": "0.1.0",
  "private": true,
  "description": "EnterpriseGPT — Production-grade enterprise AI platform that turns natural-language commands into agentic workflows. Powered by Dynamiq.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm --filter ./apps/* run dev",
    "build": "pnpm --filter ./apps/* run build",
    "lint": "pnpm --filter ./apps/* run lint",
    "test": "pnpm --filter ./apps/* run test",
    "type-check": "pnpm --filter ./apps/* run type-check",
    "web": "pnpm --filter @enterprisegpt/web",
    "api": "echo 'Use: cd apps/api && poetry run <cmd>'",
    "compose:up": "docker compose up -d",
    "compose:down": "docker compose down",
    "compose:logs": "docker compose logs -f",
    "compose:ps": "docker compose ps"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "license": "UNLICENSED"
}
