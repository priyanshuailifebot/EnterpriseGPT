# =====================================================================
# EnterpriseGPT — environment variables (copy this file to `.env`)
# =====================================================================

# ---------- App ----------
APP_NAME=EnterpriseGPT
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ---------- API server ----------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
SECRET_KEY=change-me-to-a-long-random-string-in-production
JWT_EXPIRE_MINUTES=480
JWT_REFRESH_EXPIRE_DAYS=30
CORS_ORIGINS=http://localhost:3000

# ---------- Postgres ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=enterprisegpt
POSTGRES_USER=egpt
POSTGRES_PASSWORD=egpt_dev_password
DATABASE_URL=postgresql+asyncpg://egpt:egpt_dev_password@postgres:5432/enterprisegpt

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=egpt_dev_redis_password
REDIS_URL=redis://:egpt_dev_redis_password@redis:6379/0
WEB_PUBLIC_URL=http://localhost:3000

# ---------- Self-healing monitor (headless ARQ paths only) ----------
# Interactive "Diagnose & Heal" ignores these — it always requires human accept.
AGENT_SELF_HEAL_MONITOR=false
# Global ceiling over each workflow's own policy: off | safe | autonomous.
# safe = auto-draft a fix (human publishes); autonomous = auto-publish verified fixes.
AGENT_SELF_HEAL_AUTO_APPLY=safe
AGENT_SELF_HEAL_SIMULATE=false
AGENT_SELF_HEAL_COOLDOWN_SECONDS=21600
AGENT_SELF_HEAL_MAX_PER_PASS=3
AGENT_SELF_HEAL_WINDOW_MINUTES=60
AGENT_SELF_HEAL_INTERVAL_MINUTES=60

# ---------- Workflow schedule triggers (ARQ dispatcher) ----------
# Master switch for the cron that fires schedule-triggered workflows.
WORKFLOW_SCHEDULER_ENABLED=false

# ---------- Qdrant (vector store) ----------
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ---------- MinIO (object storage) ----------
MINIO_ENDPOINT=minio:9000
MINIO_USER=egpt_minio
MINIO_PASSWORD=egpt_dev_minio_password
MINIO_BUCKET=enterprisegpt
MINIO_USE_SSL=false

# ---------- LLM provider (Azure OpenAI) ----------
# EnterpriseGPT routes ALL LLM traffic through Azure OpenAI.
# Create a deployment named e.g. `gpt-4o-mini` in Azure AI Studio and put its
# name in AZURE_OPENAI_DEPLOYMENT. The endpoint looks like:
#   https://<your-resource-name>.openai.azure.com
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_DEFAULT_MODEL=gpt-4o-mini
# Model used ONLY for workflow authoring (NL->DAG, refine, clarifying questions).
# Chat + in-workflow agents stay on AZURE_OPENAI_DEPLOYMENT. Blank = same as it.
AZURE_OPENAI_WORKFLOW_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---------- Optional LLM / Phase 2 workflow preview ----------
ANTHROPIC_API_KEY=
# Comma-separated tool names appended to NL interpreter prompts until MCP connects.
WORKFLOW_PREVIEW_TOOL_NAMES=web_search_placeholder

# ---------- Workflow NL clarification (LangGraph checkpoints, optional Azure LLM) ----------
# When enabled, POST /workflows/interpret may return status=needs_clarification before a graph is generated.
CLARIFICATION_ENABLED=true
CLARIFICATION_MAX_ROUNDS=3
CLARIFICATION_CONFIDENCE_THRESHOLD=0.75
CLARIFICATION_SESSION_TTL_SECONDS=1800

# When true, the clarifier runs an interpreter pass and yields a YES/NO confirmation round before /interpret returns ready.
CLARIFICATION_PREVIEW_BEFORE_READY=false

# ---------- LangGraph (Phase 3) ----------
# LangGraph checkpoints: redis (needs Redis-compatible server for langgraph-checkpoint-redis),
# memory (always in-memory; good for CI), auto (Redis unless DATABASE_URL contains enterprisegpt_test).
LANGGRAPH_CHECKPOINTER_MODE=memory
LANGGRAPH_CHECKPOINT_DEFAULT_TTL_MINUTES=4320

# POST URL for HelpRequest escalation webhooks from the dialog agent (optional).
HELP_ESCALATION_WEBHOOK_URL=

# ---------- Composio (MCP tool registry) ----------
# Legacy ToolSet SDK key (kept for backward compat; mostly unused now).
COMPOSIO_MCP_URL=

COMPOSIO_API_KEY=
COMPOSIO_MCP_API_KEY=
COMPOSIO_MCP_TRANSPORT=streamable-http


# ---------- Observability ----------
SENTRY_DSN=
# Langfuse tracing (Python SDK — use host/base URL of your Langfuse project)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# SDK and UI base URL, e.g. https://cloud.langfuse.com or http://langfuse:3000 in Docker
LANGFUSE_HOST=https://cloud.langfuse.com

# ---------- Langfuse self-hosted (docker-compose) ----------
# Langfuse services are optional in local dev: start with
#   docker compose --profile observability up -d
# Langfuse v3+ requires Postgres, ClickHouse, Redis, MinIO (see docker-compose.yml).
LANGFUSE_IMAGE_TAG=3.173.0
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASSWORD=change-me-langfuse-postgres
LANGFUSE_DB_NAME=langfuse
# Required by Langfuse app — use long random strings in production
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_SALT=
# Browser URL for NextAuth (local compose publishes UI on port 3100)
LANGFUSE_NEXTAUTH_URL=http://localhost:3100
# openssl rand -hex 32 — required for Langfuse v3+ (do not use the default in production)
LANGFUSE_ENCRYPTION_KEY=
LANGFUSE_CLICKHOUSE_USER=clickhouse
LANGFUSE_CLICKHOUSE_PASSWORD=change-me-langfuse-clickhouse
LANGFUSE_REDIS_PASSWORD=change-me-langfuse-redis
# Bucket on the shared MinIO service (created by langfuse-minio-init)
LANGFUSE_S3_BUCKET=langfuse
LANGFUSE_TELEMETRY_ENABLED=false
# Optional: bind mounts for docker-compose.prod volumes
DATA_ROOT=./data

# ---------- Frontend (Next.js) ----------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=EnterpriseGPT


OAUTH_REDIRECT_BASE_URL=http://localhost:3000/integrations
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
SLACK_OAUTH_CLIENT_ID=your-slack-oauth-client-id
SLACK_OAUTH_CLIENT_SECRET=your-slack-oauth-client-secret
ATLASSIAN_OAUTH_CLIENT_ID=...
ATLASSIAN_OAUTH_CLIENT_SECRET=...